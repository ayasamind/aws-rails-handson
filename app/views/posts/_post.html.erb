<div id="<%= dom_id post %>">
  <div>
    <strong>Title:</strong>
    <%= post.title %>
  </div>

  <div>
    <strong>Body:</strong>
    <%= post.body %>
  </div>

  <% if post.image.attached? %>
    <div>
      <strong>Image:</strong><br>
      <%= image_tag post.image, style: "max-width: 400px;" %>
    </div>
  <% end %>

</div>
